## Example environment variables for Vite (copy to .env and fill values)
# All client-exposed variables must start with VITE_

# Base API URL for your backend (if any)
VITE_API_URL=http://localhost:3000

# Supabase configuration (optional, required if using Supabase)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
